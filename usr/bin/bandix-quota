#!/bin/busybox sh

FORCE=0
[ "$1" = "force" ] && FORCE=1

# --- PATHS ---
BASE="/tmp/bandixpage"
WWW="/www/data"
LOCK="$BASE/bandix-quota.lock"
LOG="$BASE/bandixquota.log"
DATA="$WWW/bandix-buffer.json"
USERS_FILE="$WWW/users.json"
MAC_LOOKUP="$BASE/mac_lookup"
MAC_IP_MAP="$BASE/mac_ip_map"
USER_STATS="$BASE/user_stats"
RULE_CACHE="$BASE/firewall_rules"
HASH_FILE="$BASE/state.hash"
PAGE_PORTS="22 80 443"

mkdir -p "$BASE"

# --- LOCK ---
if ! mkdir "$LOCK" 2>/dev/null; then exit 0; fi
trap 'rm -rf "$LOCK"' EXIT INT TERM

echo "QUOTA RUN $(date -u)" > "$LOG"

# --- VALIDATE ---
[ -f "$DATA" ] || exit 0
[ -f "$USERS_FILE" ] || exit 0
jq -e . "$DATA" >/dev/null 2>&1 || exit 0
jq -e . "$USERS_FILE" >/dev/null 2>&1 || exit 0

# --- LOAD CONFIG ---
eval "$(
    jq -r '
        def shq: @sh;
        "MULT=" + ((._multiplier // 1) | tostring | shq),
        "ZONE=" + ((._zone // "lan") | tostring | shq),
        "NETWORK=" + ((._network // "192.168.1") | tostring | shq),
        "NO_BLOCK=" + ((._no_block // "") | tostring | shq)
    ' "$USERS_FILE"
)"

case "$NETWORK" in
    [0-9]*.[0-9]*.[0-9]*) ;;
    *) NETWORK="192.168.1" ;;
esac
ROUTER_IP="$NETWORK.1"

[ "$FORCE" = "1" ] && MODE="CONFIG MODE (FIREWALL REBUILD)" || MODE="NORMAL RUN (NO FIREWALL REBUILD)"
echo "[Bandix-Quota] $MODE" >> "$LOG"

# --- BUILD MAC -> IP LOOKUP IN ONE UCI PASS ---
uci show dhcp 2>/dev/null | awk -F'[.=]' '
    /^dhcp\.@host\[[0-9]+\]\.mac=/ {
        idx=$2
        mac=$0
        sub(/^[^=]*=/, "", mac)
        gsub(/\047/, "", mac)
        data[idx,"mac"]=tolower(mac)
    }
    /^dhcp\.@host\[[0-9]+\]\.ip=/ {
        idx=$2
        ip=$0
        sub(/^[^=]*=/, "", ip)
        gsub(/\047/, "", ip)
        data[idx,"ip"]=ip
    }
    END {
        for (k in data) {
            split(k, p, SUBSEP)
            idx=p[1]
            seen[idx]=1
        }
        for (idx in seen) {
            if (data[idx,"mac"] != "" && data[idx,"ip"] != "")
                print data[idx,"mac"], data[idx,"ip"]
        }
    }
' > "$MAC_IP_MAP"

# --- BUILD TRAFFIC MAP IN ONE JQ PASS ---
TRAFFIC_RAW="$BASE/traffic.raw"

if ! jq -r '
    (.devices // [])[]
    | [((.mac // "") | tostring | ascii_downcase), (((.wan_rx_bytes // 0) + (.wan_tx_bytes // 0)) | tostring)]
    | select(.[0] != "")
    | @tsv
' "$DATA" > "$TRAFFIC_RAW" 2>/dev/null; then
    echo "[Bandix-Quota] traffic jq failed" >> "$LOG"
    exit 1
fi

awk '
    { map[$1] += $2 }
    END { for (m in map) print m, map[m] }
' "$TRAFFIC_RAW" > "$MAC_LOOKUP"

# --- COMPUTE USER STATS IN ONE AWK JOIN ---
USER_MACS_RAW="$BASE/user_macs.raw"

if ! jq -r '
    to_entries[]
    | (.key | tostring) as $user
    | select($user != "")
    | select(($user | startswith("_")) | not)
    | .value as $value
    | (if ($value | type) == "object" then $value else {} end) as $obj
    | ($obj.quota // 0) as $quota
    | (
        if (($obj.macs | type) == "array") and (($obj.macs | length) > 0) then
          $obj.macs[]
        elif ($obj.macs | type) == "string" then
          $obj.macs
        elif ($obj.mac | type) == "string" then
          $obj.mac
        else
          empty
        end
      )
    | select(type == "string")
    | ascii_downcase
    | [$user, ., ($quota | tostring)]
    | @tsv
' "$USERS_FILE" > "$USER_MACS_RAW" 2>/dev/null; then
    echo "[Bandix-Quota] users jq failed" >> "$LOG"
    exit 1
fi

awk -v mult="$MULT" -v no_block="$NO_BLOCK" '
    FILENAME == ARGV[1] {
        traffic[$1] = $2
        next
    }
    {
        user=$1
        mac=$2
        quota[user]=$3 + 0
        total[user] += traffic[mac] + 0
        macs[user] = macs[user] " " mac
        has[user]=1
    }
    END {
        for (user in has) {
            gb = (total[user] / 1000000000) * mult
            over = ((gb + 0) > (quota[user] + 0)) ? 1 : 0
            if (user == no_block)
                over = 0

            printf "USER\t%s\t%.2f\t%s\t%d\t%s\n", user, gb, quota[user], over, macs[user]

            n=split(macs[user], list, " ")
            for (i=1; i<=n; i++) {
                if (list[i] == "")
                    continue
                if (over)
                    block[list[i]]=1
                else
                    allow[list[i]]=1
            }
        }

        printf "BLOCK"
        for (m in block)
            printf " %s", m
        printf "\n"

        printf "ALLOW"
        for (m in allow)
            printf " %s", m
        printf "\n"
    }
' "$MAC_LOOKUP" "$USER_MACS_RAW" > "$USER_STATS"

HAS_USERS=0
grep -q '^USER	' "$USER_STATS" && HAS_USERS=1
echo "[Bandix-Quota] HAS USERS=$HAS_USERS" >> "$LOG"

BLOCK_MACS=$(awk '$1=="BLOCK" { $1=""; print }' "$USER_STATS" | tr ' ' '\n' | grep -v '^$' | sort -u | tr '\n' ' ')
ALLOW_MACS=$(awk '$1=="ALLOW" { $1=""; print }' "$USER_STATS" | tr ' ' '\n' | grep -v '^$' | sort -u | tr '\n' ' ')

# --- LOG USERS ---
awk '
    BEGIN {
        FS="\t"
    }
    $1 == "USER" {
        user=$2
        gb=$3
        quota=$4
        over=$5 + 0
        line=sprintf("[Bandix-Quota] %-12s %-10s %-10s", user, gb, quota)

        if (over == 0) {
            allowed[++allowed_count]=line
        } else {
            blocked[++blocked_count]=line
        }
    }
    END {
        if (allowed_count > 0) {
            print "[Bandix-Quota]-----------ALLOWED USERS-----------"
            printf "[Bandix-Quota] %-12s %-10s %-10s\n", "USER", "TOTAL(GB)", "QUOTA(GB)"
            for (i=1; i<=allowed_count; i++)
                print allowed[i]
        }

        if (blocked_count > 0) {
            print "[Bandix-Quota]-----------BLOCKED USERS-----------"
            printf "[Bandix-Quota] %-12s %-10s %-10s\n", "USER", "TOTAL(GB)", "QUOTA(GB)"
            for (i=1; i<=blocked_count; i++)
                print blocked[i]
        }
    }
' "$USER_STATS" >> "$LOG"

# --- FAST EXIT IF STATE UNCHANGED ---
STATE_STRING="$(printf "%s|%s|%s|%s|%s|%s" "$HAS_USERS" "$ZONE" "$ROUTER_IP" "$PAGE_PORTS" "$BLOCK_MACS" "$ALLOW_MACS" | tr -s ' ')"

NEW_HASH=$(printf "%s" "$STATE_STRING" | md5sum | awk '{print $1}')
OLD_HASH=$(cat "$HASH_FILE" 2>/dev/null)

if [ "$NEW_HASH" = "$OLD_HASH" ] && [ "$FORCE" != "1" ]; then
    echo "[Bandix-Quota] NO STATE CHANGE" >> "$LOG"
    exit 0
fi

# --- CACHE FIREWALL RULES ONCE ---
uci show firewall 2>/dev/null | awk -F'[.=]' '
    /\.name=/ {
        section=$2
        name=$0
        sub(/^[^=]*=/, "", name)
        gsub(/\047/, "", name)
        if (name == "bandix_page" || name == "bandix_block" || name == "bandix_allowed" || name == "bandix_unknown")
            print name, section
    }
' > "$RULE_CACHE"

find_rule_index() {
    awk -v name="$1" '$1 == name { print $2; exit }' "$RULE_CACHE"
}

refresh_rule_cache() {
    uci show firewall 2>/dev/null | awk -F'[.=]' '
        /\.name=/ {
            section=$2
            name=$0
            sub(/^[^=]*=/, "", name)
            gsub(/\047/, "", name)
            if (name == "bandix_page" || name == "bandix_block" || name == "bandix_allowed" || name == "bandix_unknown")
                print name, section
        }
    ' > "$RULE_CACHE"
}

# --- DETECT NEWLY BLOCKED MACS BEFORE FIREWALL UPDATE ---
BLOCK_RULE_IDX=$(find_rule_index "bandix_block")

if [ -n "$BLOCK_RULE_IDX" ]; then
    EXISTING_BLOCK_MACS=$(uci -q get firewall.$BLOCK_RULE_IDX.src_mac 2>/dev/null | tr '\n' ' ')
else
    EXISTING_BLOCK_MACS=""
fi

NEW_BLOCK_MACS=""
for M in $BLOCK_MACS; do
    echo "$EXISTING_BLOCK_MACS" | grep -qw "$M" || NEW_BLOCK_MACS="$NEW_BLOCK_MACS $M"
done

# --- FIREWALL HELPERS ---
FW_CHANGED=0

move_rule_to_top() {
    NAME="$1"
    IDX=$(find_rule_index "$NAME")
    [ -z "$IDX" ] && return

    NUM=$(echo "$IDX" | sed 's/@rule\[\(.*\)\]/\1/')

    if uci reorder firewall.@rule[$NUM]=0; then
        FW_CHANGED=1
        refresh_rule_cache
    fi
}

move_rule_to_bottom() {
    NAME="$1"
    IDX=$(find_rule_index "$NAME")
    [ -z "$IDX" ] && return

    NUM=$(echo "$IDX" | sed 's/@rule\[\(.*\)\]/\1/')

    if uci reorder firewall.@rule[$NUM]=999; then
        FW_CHANGED=1
        refresh_rule_cache
    fi
}

ensure_rule() {
    local NAME="$1"
    local SRC="$2"
    local DEST="$3"
    local PROTO="$4"
    local TARGET="$5"
    local MACS="$6"

    IDX=$(find_rule_index "$NAME")

    if [ -z "$IDX" ]; then
        SECTION=$(uci add firewall rule) || return 1

        uci set firewall.$SECTION.name="$NAME"
        uci set firewall.$SECTION.src="$SRC"

        if [ -n "$DEST" ]; then
            if [ "$NAME" = "bandix_page" ]; then
                uci set firewall.$SECTION.dest_ip="$DEST"
            else
                uci set firewall.$SECTION.dest="$DEST"
            fi
        fi

        [ -n "$PROTO" ] && uci set firewall.$SECTION.proto="$PROTO"

        uci set firewall.$SECTION.target="$TARGET"
        uci set firewall.$SECTION.enabled='1'

        FW_CHANGED=1
        refresh_rule_cache
    else
        SECTION="$IDX"

        [ "$(uci -q get firewall.$SECTION.enabled 2>/dev/null)" != "1" ] && {
            uci set firewall.$SECTION.enabled='1'
            FW_CHANGED=1
        }

        [ "$(uci -q get firewall.$SECTION.src 2>/dev/null)" != "$SRC" ] && {
            uci set firewall.$SECTION.src="$SRC"
            FW_CHANGED=1
        }

        if [ "$NAME" = "bandix_page" ]; then
            uci delete firewall.$SECTION.dest 2>/dev/null

            [ "$(uci -q get firewall.$SECTION.dest_ip 2>/dev/null)" != "$DEST" ] && {
                uci set firewall.$SECTION.dest_ip="$DEST"
                FW_CHANGED=1
            }

            [ "$(uci -q get firewall.$SECTION.dest_port 2>/dev/null)" != "$PAGE_PORTS" ] && {
                uci set firewall.$SECTION.dest_port="$PAGE_PORTS"
                FW_CHANGED=1
            }
        else
            [ -n "$DEST" ] && [ "$(uci -q get firewall.$SECTION.dest 2>/dev/null)" != "$DEST" ] && {
                uci set firewall.$SECTION.dest="$DEST"
                FW_CHANGED=1
            }
        fi

        [ -n "$PROTO" ] && [ "$(uci -q get firewall.$SECTION.proto 2>/dev/null)" != "$PROTO" ] && {
            uci set firewall.$SECTION.proto="$PROTO"
            FW_CHANGED=1
        }

        [ "$(uci -q get firewall.$SECTION.target 2>/dev/null)" != "$TARGET" ] && {
            uci set firewall.$SECTION.target="$TARGET"
            FW_CHANGED=1
        }
    fi

    OLD_MACS=$(uci -q get firewall.$SECTION.src_mac 2>/dev/null | tr ' ' '\n' | grep -v '^$' | sort -u | tr '\n' '|')
    NEW_MACS=$(echo "$MACS" | tr ' ' '\n' | grep -v '^$' | sort -u | tr '\n' '|')

    if [ "$OLD_MACS" != "$NEW_MACS" ]; then
        uci delete firewall.$SECTION.src_mac 2>/dev/null

        for M in $MACS; do
            [ -n "$M" ] && uci add_list firewall.$SECTION.src_mac="$M"
        done

        FW_CHANGED=1
    fi
}

# --- APPLY RULES ---
if [ "$HAS_USERS" = "1" ]; then
    ensure_rule "bandix_page" "$ZONE" "$ROUTER_IP" "tcp" "ACCEPT" ""
    ensure_rule "bandix_block" "$ZONE" "*" "all" "REJECT" "$BLOCK_MACS"
    ensure_rule "bandix_allowed" "$ZONE" "*" "all" "ACCEPT" "$ALLOW_MACS"
    ensure_rule "bandix_unknown" "$ZONE" "*" "all" "REJECT" ""

    move_rule_to_bottom "bandix_allowed"
    move_rule_to_bottom "bandix_block"
    move_rule_to_bottom "bandix_unknown"
    move_rule_to_top "bandix_page"
else
    UNKNOWN_IDX=$(find_rule_index "bandix_unknown")
    if [ -n "$UNKNOWN_IDX" ]; then
        uci set firewall.$UNKNOWN_IDX.enabled='0'
        FW_CHANGED=1
        echo "[Bandix-Quota] bandix_unknown DISABLED (no users)" >> "$LOG"
    fi

    BLOCK_IDX=$(find_rule_index "bandix_block")
    if [ -n "$BLOCK_IDX" ]; then
        uci delete firewall.$BLOCK_IDX.src_mac 2>/dev/null
        uci set firewall.$BLOCK_IDX.enabled='0'
        FW_CHANGED=1
        echo "[Bandix-Quota] bandix_block CLEARED + DISABLED (no users)" >> "$LOG"
    fi

    ALLOW_IDX=$(find_rule_index "bandix_allowed")
    if [ -n "$ALLOW_IDX" ]; then
        uci delete firewall.$ALLOW_IDX.src_mac 2>/dev/null
        uci set firewall.$ALLOW_IDX.enabled='0'
        FW_CHANGED=1
        echo "[Bandix-Quota] bandix_allowed CLEARED + DISABLED (no users)" >> "$LOG"
    fi
fi

# --- SINGLE COMMIT & RELOAD ---
if [ "$FW_CHANGED" = "1" ] || [ "$FORCE" = "1" ]; then
    if ! uci commit firewall; then
        echo "[Bandix-Quota] FIREWALL COMMIT FAILED!" >> "$LOG"
        exit 1
    fi

    if ! /etc/init.d/firewall reload >/dev/null 2>&1; then
        echo "[Bandix-Quota] FIREWALL RELOAD FAILED!" >> "$LOG"
        exit 1
    fi
fi

echo "$NEW_HASH" > "$HASH_FILE"

# --- KILL CONNECTIONS ONLY FOR NEWLY BLOCKED MACS ---
get_ip_from_mac() {
    awk -v mac="$1" '$1 == mac { print $2; exit }' "$MAC_IP_MAP"
}

if [ -n "$NEW_BLOCK_MACS" ]; then
    echo "[Bandix-Quota] KILLING NEWLY BLOCKED USERS..." >> "$LOG"

    for MAC in $NEW_BLOCK_MACS; do
        IP=$(get_ip_from_mac "$MAC")

        if [ -n "$IP" ]; then
            conntrack -D -s "$IP" >/dev/null 2>&1
            conntrack -D -d "$IP" >/dev/null 2>&1
            echo "[Bandix-Quota] KILLED CONNECTIONS $MAC ($IP)" >> "$LOG"
        fi
    done
else
    echo "[Bandix-Quota] NO NEWLY BLOCKED USERS" >> "$LOG"
fi

echo "[Bandix-Quota] QUOTA DONE" >> "$LOG"
