#!/bin/busybox sh

TMP_BASE="/tmp/bandixpage"
mkdir -p "$TMP_BASE"

PASS_FILE="/usr/share/bandix-page.json"
PASS_TMP="$TMP_BASE/bandix-page.json.tmp"

DATA_FILE="/www/data/users-pay.json"
TMP_FILE="$TMP_BASE/users-pay.json.tmp"

read_post_data() {
    if [ -n "$CONTENT_LENGTH" ]; then
        read -r -n "$CONTENT_LENGTH" POST_DATA
    else
        POST_DATA=""
    fi

    # fallback to GET
    if [ -z "$POST_DATA" ]; then
        POST_DATA="$QUERY_STRING"
    fi
}

respond() {
    printf "Content-Type: application/json\r\n\r\n%s" "$1"
}

# create file if missing
init_file() {
    mkdir -p /www/data

    # Create private password file, migrating old password if it exists
    if [ ! -f "$PASS_FILE" ]; then
        OLD_PASS=$(jsonfilter -i "$DATA_FILE" -e '@.password' 2>/dev/null)
        [ -z "$OLD_PASS" ] && OLD_PASS="monitor84"

        jq -n --arg password "$OLD_PASS" '{password:$password}' > "$PASS_TMP" 2>/dev/null
        chmod 600 "$PASS_TMP" 2>/dev/null
        mv "$PASS_TMP" "$PASS_FILE"
    fi

    # Keep public file password-free
    PAID=$(jsonfilter -i "$DATA_FILE" -e '@.paid' 2>/dev/null)
    [ -z "$PAID" ] && PAID="{}"

    echo "{\"paid\":$PAID}" > "$TMP_FILE"
    mv "$TMP_FILE" "$DATA_FILE"
}

# --------------------

init_file
read_post_data
REAL_PASS=$(jsonfilter -i "$PASS_FILE" -e '@.password')

# detect GET vs POST
if echo "$POST_DATA" | grep -q '='; then
    ACTION=$(echo "$POST_DATA" | sed -n 's/^action=\([^&]*\).*/\1/p')
else
    ACTION=$(echo "$POST_DATA" | jsonfilter -e '@.action')
fi

# =========================
# GET DATA
# =========================
if [ "$ACTION" = "get" ]; then
    PASS=$(echo "$POST_DATA" | jsonfilter -e '@.password')

    [ "$PASS" = "$REAL_PASS" ] || {
        respond '{"status":"error","message":"unauthorized"}'
        exit 1
    }

    PAID=$(jsonfilter -i "$DATA_FILE" -e '@.paid')
    [ -z "$PAID" ] && PAID="{}"

    respond "{\"status\":\"ok\",\"paid\":$PAID}"
    exit 0
fi

# =========================
# LOGIN ACTION
# =========================
if [ "$ACTION" = "login" ]; then
    PASS=$(echo "$POST_DATA" | jsonfilter -e '@.password')

    if [ "$PASS" = "$REAL_PASS" ]; then
        respond '{"status":"ok"}'
    else
        respond '{"status":"error","message":"unauthorized"}'
    fi

    exit 0
fi

# =========================
# GET ZONES (NO AUTH NEEDED)
# =========================
if [ "$ACTION" = "zones" ]; then

    echo "Content-Type: application/json"
    echo ""

    echo -n "{ \"zones\": ["

    FIRST=1

    for Z in $(uci show firewall | grep "=zone" | cut -d'.' -f2 | cut -d'=' -f1); do

        NAME=$(uci get firewall.$Z.name 2>/dev/null)

        [ -z "$NAME" ] && continue

        # optional: skip wan
        # [ "$NAME" = "wan" ] && continue

        if [ $FIRST -eq 0 ]; then
            echo -n ","
        fi
        FIRST=0

        echo -n "\"$NAME\""

    done

    echo "] }"

    exit 0
fi

# =========================
# AUTH REQUIRED
# =========================
PASS=$(echo "$POST_DATA" | jsonfilter -e '@.password')

[ "$PASS" = "$REAL_PASS" ] || {
    respond '{"status":"error","message":"unauthorized"}'
    exit 1
}

# =========================
# SET PAID (🔥 FIXED)
# =========================
if [ "$ACTION" = "set_paid" ]; then

    USER=$(echo "$POST_DATA" | jsonfilter -e '@.user')
    VALUE=$(echo "$POST_DATA" | jsonfilter -e '@.value')

    echo "$USER" | grep -Eq '^[A-Za-z0-9_-]{1,32}$' || {
        respond '{"status":"error","message":"invalid_user"}'
        exit 1
    }

    EXISTING=$(jsonfilter -i "$DATA_FILE" -e '@.paid' 2>/dev/null \
        | tr '{},' '\n' \
        | grep ':' \
        | cut -d':' -f1 \
        | tr -d '" ')

    NEW_PAID="{"
    FIRST=1

    for u in $EXISTING; do
        [ "$u" = "$USER" ] && continue
        [ -z "$u" ] && continue
        echo "$u" | grep -Eq '^[A-Za-z0-9_-]{1,32}$' || continue

        if [ $FIRST -eq 0 ]; then
            NEW_PAID="$NEW_PAID,"
        fi

        NEW_PAID="$NEW_PAID\"$u\":true"
        FIRST=0
    done

    if [ "$VALUE" = "true" ]; then
        if [ $FIRST -eq 0 ]; then
            NEW_PAID="$NEW_PAID,"
        fi

        NEW_PAID="$NEW_PAID\"$USER\":true"
    fi

    NEW_PAID="$NEW_PAID}"

    echo "{\"paid\":$NEW_PAID}" > "$TMP_FILE"
    mv "$TMP_FILE" "$DATA_FILE"

    respond '{"status":"ok"}'
    exit 0
fi


# =========================
# CHANGE PASSWORD
# =========================
if [ "$ACTION" = "set_password" ]; then

    NEW=$(echo "$POST_DATA" | jsonfilter -e '@.new')

    [ -n "$NEW" ] || {
        respond '{"status":"error","message":"empty_password"}'
        exit 1
    }

    jq -n --arg password "$NEW" '{password:$password}' > "$PASS_TMP" 2>/dev/null || {
        respond '{"status":"error","message":"password_write_failed"}'
        exit 1
    }

    chmod 600 "$PASS_TMP" 2>/dev/null
    mv "$PASS_TMP" "$PASS_FILE"

    respond '{"status":"ok"}'
    exit 0
fi

respond '{"status":"error"}'
