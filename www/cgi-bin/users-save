#!/bin/busybox sh

TMP_BASE="/tmp/bandixpage"
LOG_DIR="$TMP_BASE"

mkdir -p "$TMP_BASE"

LOG="$LOG_DIR/bandixusers.log"
LOCK="$TMP_BASE/bandix-users.lock"

DATA_FILE="/www/data/users.json"
PAY_FILE="/usr/share/bandix-page.json"
PAID_FILE="/www/data/users-pay.json"
PAID_CLEAN_TMP="$TMP_BASE/users-pay.clean.tmp"
TMP_FILE="$TMP_BASE/users.json.tmp"
POST_FILE="$TMP_BASE/users.post.$$"
CACHE="$TMP_BASE/bandix.cache"
TMP_UCI="$TMP_BASE/bandix.uci"
MAX_SIZE=65536

echo "RUN $(date)" > "$LOG"

respond() {
    printf "Content-Type: application/json\r\n"
    printf "\r\n"
    printf "%s" "$1"
}

# --- ATOMIC LOCK ---
if [ -d "$LOCK" ]; then
    AGE=$(( $(date +%s) - $(stat -c %Y "$LOCK" 2>/dev/null || echo 0) ))
    if [ "$AGE" -gt 30 ]; then
        echo "[Bandix-Page] REMOVE STALE LOCK" >> "$LOG"
        rm -rf "$LOCK"
    fi
fi

if ! mkdir "$LOCK" 2>/dev/null; then
    echo "[Bandix-Page] LOCKED" >> "$LOG"
    respond '{"status":"error","message":"locked"}'
    exit 0
fi

cleanup() {
    rm -rf "$LOCK"
    rm -f "$POST_FILE" "$TMP_FILE" "$PAID_CLEAN_TMP" "$TMP_UCI"
}
trap cleanup EXIT INT TERM

# --- WEB SYMLINKS ---
ensure_symlink() {
    TARGET="$1"
    LINK="$2"

    [ "$(readlink "$LINK" 2>/dev/null)" = "$TARGET" ] && return
    ln -sf "$TARGET" "$LINK"
}

ensure_symlink "$TMP_BASE/devices.txt" "/www/devices.txt"
mkdir -p /www/data
ensure_symlink "$TMP_BASE/bandix-buffer.json" "/www/data/bandix-buffer.json"
ensure_symlink "$TMP_BASE/bandixquota.log" "/www/data/bandixquota.log"

# --- LOAD PASSWORD ---
if [ ! -f "$PAY_FILE" ]; then
    respond '{"status":"error","message":"password_file_missing"}'
    exit 1
fi

PASSWORD=$(jq -r '.password // empty' "$PAY_FILE" 2>/dev/null)

[ -n "$PASSWORD" ] || {
    respond '{"status":"error","message":"password_not_set"}'
    exit 1
}

clean_paid_users() {
    [ -f "$PAID_FILE" ] || return 0
    [ -f "$DATA_FILE" ] || return 0

    jq -n \
      --slurpfile users "$DATA_FILE" \
      --slurpfile paid "$PAID_FILE" '
        ($users[0] // {}) as $users |
        ($paid[0].paid // {}) as $paid |
        {
          paid: reduce ($paid | keys_unsorted[]) as $u ({};
            if (($users | has($u)) and ($u | startswith("_") | not)) then
              . + {($u): true}
            else
              .
            end
          )
        }
      ' > "$PAID_CLEAN_TMP" 2>/dev/null || return 0

    if ! cmp -s "$PAID_CLEAN_TMP" "$PAID_FILE" 2>/dev/null; then
        cp "$PAID_CLEAN_TMP" "$PAID_FILE"
    fi
}

read_post_data() {
    case "$CONTENT_LENGTH" in
        ""|*[!0-9]*)
            cat
            ;;
        0)
            return 0
            ;;
        *)
            dd bs="$CONTENT_LENGTH" count=1 2>/dev/null
            ;;
    esac
}

get_cache_meta() {
    awk -F'|' -v key="$1" '$1 == "META" && $2 == key { print $3; exit }' "$CACHE"
}

get_network_from_cache() {
    NETWORK=$(get_cache_meta network)
    [ -z "$NETWORK" ] && NETWORK="192.168.1"

    case "$NETWORK" in
        [0-9]*.[0-9]*.[0-9]*) ;;
        *) NETWORK="192.168.1" ;;
    esac
}

build_cache() {
    jq -r '
        def val($k): (.[$k] // "");
        "META|network|\(val("_network"))",
        "META|refresh|\(val("_refresh"))",
        "META|multiplier|\(val("_multiplier"))",
        "META|admin|\(val("_no_block"))",
        "META|zone|\(val("_zone"))",
        (
            to_entries[]
            | (.key | tostring) as $user
            | select($user != "")
            | select(($user | startswith("_")) | not)
            | select(($user | index("|")) == null)
            | .value as $value
            | (if ($value | type) == "object" then $value else {} end) as $obj
            | ($obj.quota // 0) as $quota
            | (
                if (($obj.macs | type) == "array") and (($obj.macs | length) > 0) then
                  $obj.macs[]
                elif ($obj.macs | type) == "string" then
                  $obj.macs
                elif ($obj.mac | type) == "string" then
                  $obj.mac
                else
                  empty
                end
              )
            | select(type == "string")
            | ascii_upcase
            | . as $mac
            | ($mac | split(":")) as $parts
            | select(($mac | length) == 17 and ($parts | length) == 6)
            | select(([ $parts[] | select(length == 2) ] | length) == 6)
            | "\($user)|\($mac)|\($quota)"
        )
    ' "$DATA_FILE" > "$CACHE"
}

add_dhcp_leases() {
    get_network_from_cache

    uci show dhcp 2>/dev/null | awk -F'[.=]' '
        $3 == "tag" {
            value=$0
            sub(/^[^=]*=/, "", value)
            gsub(/\047/, "", value)
            if (value == "bandix") {
                idx=$2
                gsub(/@host\[|\]/, "", idx)
                print idx
            }
        }
    ' | sort -rn | awk '
        $1 != "" { print "delete dhcp.@host[" $1 "]" }
    ' > "$TMP_UCI"

    awk -F'|' -v network="$NETWORK" '
        $1 == "META" { next }
        {
            user=$1
            mac=toupper($2)

            if (user != current_user) {
                current_user=user
                mac_index=0
                base=10 + user_index * 5
                user_index++
            }

            last=base + mac_index

            if (last < 10 || last > 254) {
                mac_index++
                next
            }

            ip=network "." last
            name=user "-" (mac_index + 1)

            print "add dhcp host"
            print "set dhcp.@host[-1].name=" name
            print "set dhcp.@host[-1].mac=" mac
            print "set dhcp.@host[-1].ip=" ip
            print "set dhcp.@host[-1].leasetime=infinite"
            print "set dhcp.@host[-1].tag=bandix"

            mac_index++
        }
    ' "$CACHE" >> "$TMP_UCI"

    # Split delete and add into separate batches to avoid index shifting aborts
    grep '^delete' "$TMP_UCI" | uci batch >/dev/null 2>&1
    grep -v '^delete' "$TMP_UCI" | uci batch >/dev/null 2>&1 || {
        echo "[Bandix-Page] uci batch add failed" >> "$LOG"
        return 1
    }

    if ! uci commit dhcp >/dev/null 2>&1; then
        echo "[Bandix-Page] uci commit failed" >> "$LOG"
        return 1
    fi

    : > /tmp/dhcp.leases 2>/dev/null
    ip neigh flush all >/dev/null 2>&1

    (
        ubus call service reload '{"name":"dnsmasq"}' >/dev/null 2>&1 \
            || /etc/init.d/dnsmasq restart >/dev/null 2>&1
    ) &

    return 0
}

generate_dhcp_fp() {
    awk -F'|' '
        function checked_network() {
            if (!network_checked) {
                if (network !~ /^[0-9]+\.[0-9]+\.[0-9]+$/)
                    network="192.168.1"
                network_checked=1
            }
            return network
        }

        $1 == "META" && $2 == "network" {
            network=$3
            next
        }

        $1 == "META" {
            next
        }

        {
            user=$1
            mac=toupper($2)

            if (user != current_user) {
                current_user=user
                mac_index=0
                base=10 + user_index * 5
                user_index++
            }

            last=base + mac_index

            if (last < 10 || last > 254) {
                mac_index++
                next
            }

            printf "%s-%d|%s|%s.%d\n", user, mac_index + 1, mac, checked_network(), last
            mac_index++
        }
    ' "$CACHE" | sort | md5sum | cut -d' ' -f1
}

generate_quota_fp() {
    awk -F'|' '
        $1 == "META" {
            meta[$2]=$3
            next
        }

        {
            quota=$3
            if (quota == "")
                quota=0
            print $1 "|" toupper($2) "|" quota
        }

        END {
            multiplier=meta["multiplier"]
            if (multiplier == "")
                multiplier=1

            print "MULTIPLIER=" multiplier
            print "ADMIN=" meta["admin"]
            print "ZONE=" meta["zone"]
            print "NETWORK=" meta["network"]
        }
    ' "$CACHE" | sort | md5sum | cut -d' ' -f1
}

update_cron() {
    REFRESH=$(get_cache_meta refresh)

    [ -z "$REFRESH" ] && REFRESH=2
    echo "$REFRESH" | grep -Eq '^[0-9]+$' || REFRESH=2
    [ "$REFRESH" -lt 1 ] && REFRESH=1
    [ "$REFRESH" -gt 60 ] && REFRESH=60

    CRON_FILE="/etc/crontabs/root"
    TMP_CRON="$TMP_BASE/root.cron.tmp"

    if [ -f "$CRON_FILE" ]; then
        grep -v 'bandix-quota' "$CRON_FILE" > "$TMP_CRON"
    else
        : > "$TMP_CRON"
    fi

    echo "*/$REFRESH * * * * /usr/bin/bandix-quota" >> "$TMP_CRON"

    if cmp -s "$TMP_CRON" "$CRON_FILE" 2>/dev/null; then
        rm -f "$TMP_CRON"
        echo "[Bandix-Page] cron already correct" >> "$LOG"
        return 0
    fi

    cp "$TMP_CRON" "$CRON_FILE"
    rm -f "$TMP_CRON"

    /etc/init.d/cron restart
}

generate_actual_dhcp_fp() {
    uci show dhcp 2>/dev/null | awk -F'[.=]' '
        /^dhcp\.@host\[[0-9]+\]\./ {
            section=$2
            prop=$3
            value=$0
            sub(/^[^=]*=/, "", value)
            gsub(/\047/, "", value)

            data[section,prop]=value
            sections[section]=1
        }

        END {
            for (section in sections) {
                if (data[section,"tag"] == "bandix" &&
                    data[section,"name"] != "" &&
                    data[section,"mac"] != "" &&
                    data[section,"ip"] != "") {
                    print data[section,"name"] "|" toupper(data[section,"mac"]) "|" data[section,"ip"]
                }
            }
        }
    ' | sort | md5sum | cut -d' ' -f1
}

# -------------------------

read_post_data > "$POST_FILE"

[ -s "$POST_FILE" ] || {
    respond '{"status":"error","message":"empty"}'
    exit 1
}

SIZE=$(wc -c < "$POST_FILE" | tr -d ' ')
[ "$SIZE" -le "$MAX_SIZE" ] || {
    respond '{"status":"error","message":"too_large"}'
    exit 1
}

jq -e . "$POST_FILE" >/dev/null 2>&1 || {
    respond '{"status":"error","message":"invalid_json"}'
    exit 1
}

ACTION=$(jq -r '.action // empty' "$POST_FILE" 2>/dev/null)
PASS=$(jq -r '.password // empty' "$POST_FILE" 2>/dev/null)

if [ "$ACTION" = "cleanup" ]; then
    [ "$PASS" = "$PASSWORD" ] || {
        respond '{"status":"error","message":"unauthorized"}'
        exit 1
    }

    echo "[Bandix-Page] CLEANUP TRIGGERED" >> "$LOG"

    rm -rf /usr/share/bandix/* 2>> "$LOG"

    /etc/init.d/bandix restart >> "$LOG" 2>&1 || {
        echo "[Bandix-Page] restart failed" >> "$LOG"
        respond '{"status":"error","message":"restart_failed"}'
        exit 1
    }

    respond '{"status":"ok"}'
    exit 0
fi

[ "$PASS" = "$PASSWORD" ] || {
    respond '{"status":"error","message":"unauthorized"}'
    exit 1
}

if ! jq -c 'if (.data | type) == "object" then .data else empty end' "$POST_FILE" > "$TMP_FILE" 2>/dev/null; then
    respond '{"status":"error","message":"invalid_json"}'
    exit 1
fi

[ -s "$TMP_FILE" ] || {
    respond '{"status":"error","message":"no_data"}'
    exit 1
}

jq -e . "$TMP_FILE" >/dev/null 2>&1 || {
    respond '{"status":"error","message":"invalid_json"}'
    exit 1
}

mkdir -p /www/data

if ! cmp -s "$TMP_FILE" "$DATA_FILE" 2>/dev/null; then
    cp "$TMP_FILE" "$DATA_FILE" || exit 1
    echo "[Bandix-Page] users.json changed" >> "$LOG"
else
    echo "[Bandix-Page] users.json unchanged" >> "$LOG"
fi

clean_paid_users

build_cache || {
    echo "[Bandix-Page] build_cache failed" >> "$LOG"
    respond '{"status":"error","message":"cache_failed"}'
    exit 1
}

cat "$CACHE" >> "$LOG"

[ -s "$DATA_FILE" ] || {
    echo "[Bandix-Page] ERROR: users.json empty" >> "$LOG"
    exit 1
}

DHCP_FP_FILE="$TMP_BASE/bandix_dhcp.fp"
REFRESH_FP_FILE="$TMP_BASE/bandix_refresh.fp"
QUOTA_FP_FILE="$TMP_BASE/bandix_quota.fp"

NEW_QUOTA_FP="$(generate_quota_fp)"
OLD_QUOTA_FP="$(cat "$QUOTA_FP_FILE" 2>/dev/null)"

NEW_DHCP_FP="$(generate_dhcp_fp)"
OLD_DHCP_FP="$(cat "$DHCP_FP_FILE" 2>/dev/null)"
ACTUAL_DHCP_FP="$(generate_actual_dhcp_fp)"

NEW_REFRESH=$(get_cache_meta refresh)
echo "$NEW_REFRESH" | grep -Eq '^[0-9]+$' || NEW_REFRESH=2
OLD_REFRESH="$(cat "$REFRESH_FP_FILE" 2>/dev/null)"

# ---- DHCP changes ----
if [ "$NEW_DHCP_FP" != "$OLD_DHCP_FP" ] || [ "$NEW_DHCP_FP" != "$ACTUAL_DHCP_FP" ]; then
    echo "[Bandix-Page] DHCP changed/missing -> rebuilding" >> "$LOG"

    if add_dhcp_leases; then
        echo "$NEW_DHCP_FP" > "$DHCP_FP_FILE"
        /usr/bin/generate-hosts.sh >> "$LOG" 2>&1 || true
    else
        echo "[Bandix-Page] DHCP rebuild failed" >> "$LOG"
        respond '{"status":"error","message":"dhcp_failed"}'
        exit 1
    fi
else
    echo "[Bandix-Page] DHCP unchanged" >> "$LOG"
fi

# ---- REFRESH changes ----
if [ "$NEW_REFRESH" != "$OLD_REFRESH" ]; then
    echo "[Bandix-Page] REFRESH changed -> updating cron" >> "$LOG"

    update_cron
    echo "$NEW_REFRESH" > "$REFRESH_FP_FILE"
else
    echo "[Bandix-Page] REFRESH unchanged" >> "$LOG"
fi

# ---- QUOTA changes ----
if [ "$NEW_QUOTA_FP" != "$OLD_QUOTA_FP" ]; then
    echo "[Bandix-Page] QUOTA changed -> applying" >> "$LOG"

    /usr/bin/bandix-quota force >> "$LOG" 2>&1 || true
    echo "$NEW_QUOTA_FP" > "$QUOTA_FP_FILE"
else
    echo "[Bandix-Page] QUOTA unchanged" >> "$LOG"
fi

respond '{"status":"ok"}'
exit 0
